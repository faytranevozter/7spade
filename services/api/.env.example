# API Service

# Server listen port
PORT=8080

# Required: JWT signing secret
JWT_SECRET=

# Required: PostgreSQL connection URL
DATABASE_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable

# Required: Redis connection URL (used for OAuth state/PKCE storage)
REDIS_URL=redis://localhost:6379/0

# Frontend URL (used to build OAuth callback redirect URLs)
FRONTEND_URL=http://localhost:5173

# Comma-separated origins allowed to make credentialed browser requests to the API.
# Required for HttpOnly refresh-token cookies. Do not use "*" with credentials.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# OAuth state signing secret (falls back to JWT_SECRET if empty)
OAUTH_STATE_SECRET=

# Google OAuth 2.0 + OIDC
# Set up at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must match a URI registered in Google Cloud Console
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:5173/auth/callback/google

# GitHub OAuth 2.0 (plain OAuth, no OIDC)
# Set up at: GitHub → Settings → Developer settings → OAuth Apps
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Must match the Authorization callback URL registered in GitHub
GITHUB_OAUTH_REDIRECT_URL=http://localhost:5173/auth/callback/github

# Telegram OIDC (Authorization Code + PKCE)
# Set up via @BotFather → Bot Settings → Web Login
# client_id  = numeric Bot ID (e.g. 1234567890)
# client_secret = secret from @BotFather
# redirect_url must be registered in @BotFather before use
TELEGRAM_OAUTH_CLIENT_ID=
TELEGRAM_OAUTH_CLIENT_SECRET=
TELEGRAM_OAUTH_REDIRECT_URL=http://localhost:5173/auth/callback/telegram

# Transactional email (password reset / email verification).
# When SMTP_HOST is empty the API logs the links to stdout (dev default) and
# sends no mail — no SMTP server required for local development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# From address used on outgoing mail.
SMTP_FROM=no-reply@sevenspade.local
# Display name on the From header, e.g. "Seven Spade <no-reply@...>".
SMTP_FROM_NAME=Seven Spade
# Optional Reply-To address (leave empty to omit).
SMTP_REPLY_TO=
# Transport security: auto | tls | starttls | none.
# auto = implicit TLS on port 465, STARTTLS otherwise. Use "none" only for a
# local test inbox like Mailpit (SMTP on :1025).
SMTP_ENCRYPTION=auto

