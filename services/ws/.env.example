# WebSocket Service

# Server listen port
PORT=8081

# JWT signing secret (must match the API service)
JWT_SECRET=

# PostgreSQL connection URL
DATABASE_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Dedicated Redis for the cross-replica relay (pub/sub, owner leases, room
# snapshots). Falls back to REDIS_URL when unset, so single-replica deploys can
# leave this blank. Point all ws replicas at the SAME instance.
WS_REDIS_URL=

# External API base URL for persisting game history (disabled if empty)
API_URL=
